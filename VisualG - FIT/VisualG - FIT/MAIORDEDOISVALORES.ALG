Algoritmo "MaiorDeDoisValores"
// Disciplina  : Lµgica de ProgramaÓÐo
// Professor   : Jailson
// DescriÓÐo   : Lõ dois valores e exibe apenas o maior deles
// Autor(a)    : Grasiely Aparecida Martins
// Data atual  : 17/04/2026
Var
   primeiroValorLido, segundoValorLido: real

Inicio
   escreva("Digite o primeiro valor: ")
   leia(primeiroValorLido)
   escreva("Digite o segundo valor: ")
   leia(segundoValorLido)

   se (primeiroValorLido > segundoValorLido) entao
      escreva("O maior valor informado Õ: ", primeiroValorLido)
   senao
      escreva("O maior valor informado Õ: ", segundoValorLido)
   fimse

Fimalgoritmo