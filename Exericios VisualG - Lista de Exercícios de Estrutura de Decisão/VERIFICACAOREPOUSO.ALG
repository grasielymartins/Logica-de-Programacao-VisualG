Algoritmo "VerificacaoRepouso"
// Disciplina  : Lógica de Programaçăo
// Professor   : Jailson
// Descriçăo   : Alerta se o aluno estudou mais de 10 horas
// Autor(a)    : Grasiely Aparecida Martins
// Data atual  : 17/04/2026
Var
   horas: real

Inicio
   escreva("Quantas horas vocę estudou hoje? ")
   leia(horas)
   se (horas > 10) entao
      escreva("Aviso: Necessário intervalo para descanso")
   fimse

Fimalgoritmo