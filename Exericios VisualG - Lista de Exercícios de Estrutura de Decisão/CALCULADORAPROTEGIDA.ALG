Algoritmo "CalculadoraProtegida"
// Disciplina  : Lógica de Programaçăo
// Professor   : Jailson
// Descriçăo   : Realiza cálculos básicos e protege contra divisăo por zero
// Autor(a)    : Grasiely Aparecida Martins
// Data atual  : 17/04/2026
Var
   valorUm, valorDois, resultadoCalculo: real
   operacaoMatematica: caractere

Inicio
   escreva("Digite o primeiro número: ")
   leia(valorUm)
   escreva("Digite o segundo número: ")
   leia(valorDois)
   escreva("Operaçăo (+, -, *, /): ")
   leia(operacaoMatematica)

   se (operacaoMatematica = "+") entao
      resultadoCalculo <- valorUm + valorDois
      escreva("Resultado: ", resultadoCalculo)
   senao
      se (operacaoMatematica = "-") entao
         resultadoCalculo <- valorUm - valorDois
         escreva("Resultado: ", resultadoCalculo)
      senao
         se (operacaoMatematica = "*") entao
            resultadoCalculo <- valorUm * valorDois
            escreva("Resultado: ", resultadoCalculo)
         senao
            se (operacaoMatematica = "/") entao
               se (valorDois <> 0) entao
                  resultadoCalculo <- valorUm / valorDois
                  escreva("Resultado: ", resultadoCalculo)
               senao
                  escreva("Erro: Divisăo por zero")
               fimse
            fimse
         fimse
      fimse
   fimse

Fimalgoritmo