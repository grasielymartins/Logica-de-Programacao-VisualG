Algoritmo "L02K"
// Disciplina  : Lógica de Programaçăo
// Professor   : Jailson
// Descriçăo   : Lę um número e o apresenta apenas se ele năo for maior que 3.
// Autor(a)    : Grasiely Aparecida Martins
// Data atual  : 19/04/2026
Var
   numeroInteiroLido: inteiro

Inicio
   escreva("Digite um número: ")
   leia(numeroInteiroLido)

   se (nao (numeroInteiroLido > 3)) entao
      escreva("Valor: ", numeroInteiroLido)
   fimse

Fimalgoritmo